{
  "buildCommand": "cd greenline-website && npm install && npm run build",
  "outputDirectory": "greenline-website/.next",
  "installCommand": "echo 'install handled in buildCommand'",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/meetings/:path*",
      "destination": "https://meetings.hubspot.com/greenline-activations/:path*",
      "permanent": true
    },
    {
      "source": "/documents/:path*",
      "destination": "https://app.hubspot.com/documents/:path*",
      "permanent": true
    }
  ]
}
